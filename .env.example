# ScentScout environment template — copy to `.env` and fill in real values.
# NEVER commit a real .env. All secrets stay out of git.

# --- Database (PostgreSQL / Supabase) ---
# Pooled connection string used by the app at runtime.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Direct (non-pooled) connection used by Drizzle migrations.
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Email (Resend) ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
ALERTS_FROM_EMAIL="alerts@scentscout.example"

# --- Error monitoring (Sentry) ---
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# --- App ---
# Dev runs on 3004 (3000/3003 are taken by sibling projects). In production this
# must be the real origin — it is used for canonical URLs, sitemap.xml, robots.txt
# and OpenGraph tags, so a wrong value ships wrong links to search engines.
NEXT_PUBLIC_SITE_URL="http://localhost:3004"
# Comma-separated admin emails allowed to access /admin (temporary until RBAC lands).
ADMIN_EMAILS=""

# Alert email delivery (Resend). Without RESEND_API_KEY, alerts are recorded but
# never sent — they stay `pending` rather than being marked delivered.
ALERT_FROM_EMAIL="ScentScout <alerts@yourdomain.com>"
